<!DOCTYPE html>
<html lang="it">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <title>Catalogo Libri - MyReadings</title>
</head>

<body>
  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light">
    <a class="navbar-brand" href="/">
      <img src="/images/logo.png" class="navbar-icon" width="48" height="48" alt="MyReadings"> MyReadings
    </a>
    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav"
      aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav mr-auto">
        <li class="nav-item">
          <a class="nav-link" href="/books">Biblioteca</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/mybooks">Miei</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/reviews">Recensioni</a>
        </li>
        <% if (user && user.role==='autore' ) { %>
          <li class="nav-item">
            <a class="nav-link" href="/addbook">Aggiungi</a>
          </li>
          <% } %>
            <li class="nav-item">
              <a class="nav-link" href="/notifications">Notifiche</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/contacts">Contatti</a>
            </li>
            <% if (user) { %>
              <li class="nav-item">
                <a class="nav-link text-danger" href="/logout">Logout</a>
              </li>
              <% } %>
      </ul>
      <form class="form-inline" action="/search" method="GET">
        <input class="form-control mr-sm-2" type="search" name="q" placeholder="Cerca libri e autori"
          aria-label="Search">
        <button class="btn btn-outline-success my-2 my-sm-0" type="submit">Cerca</button>
      </form>
    </div>
  </nav>

  <!-- CONTENUTO PAGINA -->
  <div class="container my-5">
    <h1 class="text-center mb-5 page-title">Recensioni degli altri lettori</h1>
    <% if (reviews.length===0) { %>
      <p class="text-center">Nessuna recensione disponibile.</p>
    <% } else { %>
        <div class="row">
        <!-- RECENSIONI -->
          <% reviews.forEach(review=> { %>
            <div class="col-md-6">
              <div class="card mb-4 review-card">
                <div class="row no-gutters">
                  <!-- Colonna testo -->
                  <div class="col-md-8">
                    <div class="card-body d-flex flex-column justify-content-between h-100">
                      <div>
                        <h5 class="card-title font-weight-bold">
                          <%= review.title %>
                        </h5>
                        <p class="card-text">
                          <%= review.review %>
                        </p>
                        <p class="card-text">
                          Valutazione:
                          <% for (let i=1; i <=5; i++) { %>
                            <i class="fa fa-star<%= i <= review.rating ? '' : '-o' %>"></i>
                          <% } %>
                        </p>
                        <p class="text-muted">Recensito da 
                          <strong>
                            <%= review.name %>
                            <%= review.surname %>
                          </strong> il <%= new Date(review.created_at).toLocaleDateString("it-IT") %>
                        </p>
                      </div>

                      <!-- Azioni -->
                      <form action="/api/review/comment" method="POST" class="mt-3">
                        <input type="hidden" name="review_id" value="<%= review.id %>">
                        <div class="form-group">
                          <textarea name="comment" class="form-control" rows="2"
                            placeholder="Scrivi un commento..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-discover-more">Commenta</button>
                      </form>
                    </div>
                  </div>

                  <!-- Colonna immagine -->
                  <div class="col-md-4 d-flex flex-column align-items-center justify-content-center">
                    <img src="/<%= review.cover || 'images/book-placeholder.jpg' %>"
                      alt="Copertina di <%= review.title %>" class="img-fluid rounded-start review-book-cover">
                    <!-- Pulsanti Like/Dislike -->
                    <div class="mt-3">
                      <form action="/api/review/like" method="POST" class="d-inline">
                        <input type="hidden" name="review_id" value="<%= review.id %>">
                        <button name="type" value="like" class="btn btn-outline-success my-2 my-sm-0">Like</button>
                        <button name="type" value="dislike"
                          class="btn btn-outline-success my-2 my-sm-0">Dislike</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
  </div>

  <footer class="footer">
    © 2025 Copyright: MyReadings
  </footer>

  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.16.0/umd/popper.min.js"></script>
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
  <script src="/javascripts/submit.js"></script>
</body>

</html>