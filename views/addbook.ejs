<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aggiungi un libro - MyReadings</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/styles.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <a class="navbar-brand" href="/">
            <img src="images/logo.png" class="navbar-icon" width="48" height="48" alt="MyReadings"> MyReadings
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav"
            aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item">
                    <a class="nav-link" href="/books">Biblioteca</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/mybooks">Miei</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/reviews">Recensioni</a>
                </li>
                <% if (user && user.role==='autore' ) { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/addbook">Aggiungi</a>
                    </li>
                <% } %>

                        <li class="nav-item">
                            <a class="nav-link" href="/notifications">Notifiche</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/contacts">Contatti</a>
                        </li>
                        <% if (user) { %>
                            <li class="nav-item">
                                <a class="nav-link text-danger" href="/logout">Logout</a>
                            </li>
                        <% } %>
            </ul>
            <form class="form-inline" action="/search" method="GET">
                <input class="form-control mr-sm-2" type="search" name="q" placeholder="Cerca libri e autori"
                    aria-label="Search">
                <button class="btn btn-outline-success my-2 my-sm-0" type="submit">Cerca</button>
            </form>
        </div>
    </nav>

    <!-- CONTENUTO PAGINA -->
    <!-- Modulo per aggiungere un libro (solo per autori) -->
    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <h1 class="text-center mb-4">Aggiungi un nuovo libro</h1>
                <!-- Form per l'aggiunta di un libro -->
                <form action="/addbook" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="title">Titolo</label>
                        <input type="text" class="form-control" id="title" name="title"
                            placeholder="Inserisci il titolo del libro" required>
                    </div>

                    <div class="form-group">
                        <label for="author">Autore</label>
                        <input type="text" class="form-control" id="author" name="author"
                            value="<%= user.name + ' ' + user.surname %>" readonly>
                    </div>

                    <div class="form-group">
                        <label for="pages">Numero di pagine</label>
                        <input type="number" class="form-control" id="pages" name="pages" placeholder="Es. 720"
                            required>
                    </div>

                    <div class="form-group">
                        <label for="cover">Carica Copertina (file)</label>
                        <input type="file" class="form-control" id="cover" name="cover" accept="image/*" required>
                    </div>

                    <div class="form-group">
                        <label for="publication_date">Anno di Pubblicazione</label>
                        <input type="number" class="form-control" id="publication_date" name="publication_date"
                            placeholder="Anno di pubblicazione" required>
                    </div>

                    <div class="form-group">
                        <label for="publisher">Casa Editrice</label>
                        <input type="text" class="form-control" id="publisher" name="publisher"
                            placeholder="Inserisci la casa editrice" required>
                    </div>

                    <div class="form-group">
                        <label for="genre">Genere</label>
                        <select class="form-control" id="genre" name="genre" required>
                            <option value="" disabled selected>Seleziona un genere</option>
                            <option>Fantasy</option>
                            <option>Fiction</option>
                            <option>Thriller</option>
                            <option>Fantascienza</option>
                            <option>Non-Fiction</option>
                            <option>Memoir</option>
                            <option>Romance</option>
                            <option>Horror</option>
                            <option>Storico</option>
                            <option>Literary Fiction</option>
                            <option>Young Adult</option>
                            <option>Children's</option>
                            <option>Graphic Novel</option>
                            <option>Distopico</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="description">Descrizione</label>
                        <textarea class="form-control" id="description" name="description" rows="3"
                            placeholder="Inserisci una breve descrizione del libro"></textarea>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-discover-more">Aggiungi libro</button>
                    </div>
                </form>
            </div>
        </div>
    </div>


    <!-- Footer e altre informazioni già esistenti nel progetto -->
    <footer class="footer">
        © 2025 Copyright: MyReadings
    </footer>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.16.0/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>

</html>